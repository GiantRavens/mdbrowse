#!/bin/sh
# mdb — v2 launcher, living next to its .venv (house pattern: forge CLIs
# sit beside their venv and are invoked by path or from the repo).
# The venv is host-local and never synced; each machine builds its own.
here="$(cd "$(dirname "$0")" && pwd)"
py="$here/.venv/bin/python"
if [ ! -x "$py" ]; then
    echo "mdb: no venv at $here/.venv" >&2
    echo "  build it:  cd $here && uv venv && uv pip install -e . && .venv/bin/playwright install chromium" >&2
    exit 1
fi
exec "$py" -m mdb.cli "$@"
